PORT=4000
APP_URL=http://127.0.0.1:5173
DAILY_SUMMARY_HOUR=21

# Optional email reminders and daily summaries.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=app-password
MAIL_FROM=Daily Planner <you@example.com>

# Optional LLM coaching. Without this, the app uses a local fallback summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Hosted storage. Leave empty for local JSON storage in data/planner.json.
DATABASE_URL=
DATABASE_SSL=true
